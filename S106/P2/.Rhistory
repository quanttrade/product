library(sparseIndexTracking)
library(zoo)
library(xts)
library(R.matlab)
importData <-function(csvFileName){
x1<-read.table(csvFileName,header=T, sep=",")
x2<-x1
x1[1]<-NULL
x1<-data.matrix(x1)
rownames(x1)<-x2$X
x1=as.xts(x1)
return(x1)
}
