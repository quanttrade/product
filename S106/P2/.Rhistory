r_train<-importData(fn2)
if (method_sel==1)
{
w <- spIndexTrack(X_train, r_train, lambda = 1e-7, u = 0.5, measure = 'ete')
}
if (method_sel==2)
{
w <- spIndexTrack(X_train, r_train, lambda = 2e-8, u = 0.5, measure = 'dr')
}
if (method_sel==3)
{
w <- spIndexTrack(X_train, r_train, lambda = 8e-8, u = 0.5, measure = 'hete', hub = 0.05)
}
if (method_sel==4)
{
